{
	"name": "hyperlayering-org",
	"compatibility_flags": ["nodejs_compat"],
	"compatibility_date": "2026-07-05",
	"assets": {
		"directory": "./dist"
	},
	"observability": {
		"enabled": false,
		"head_sampling_rate": 1,
		"logs": {
			"enabled": true,
			"head_sampling_rate": 1,
			"persist": true,
			"invocation_logs": true
		},
		"traces": {
			"enabled": false,
			"persist": true,
			"head_sampling_rate": 1
		}
	}
}
