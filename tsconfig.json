{
	"extends": "astro/tsconfigs/strict",
	"include": [".astro/types.d.ts", "**/*", "./worker-configuration.d.ts"],
	"exclude": ["dist"],
	"compilerOptions": {
		"types": ["./worker-configuration.d.ts"],
		"paths": {
			"components/*": ["./src/components/*"],
			"layouts/*": ["./src/layouts/*"],
			"styles/*": ["./src/styles/*"],
			"images/*": ["./src/images/*"],
			"assets/*": ["./src/assets/*"],
			"i18n/*": ["./src/i18n/*"]
		}
	}
}
