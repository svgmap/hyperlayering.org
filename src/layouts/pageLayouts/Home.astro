---
import LandingWindow from "components/LandingWindow.svelte";
import { getLangFromUrl, useTranslations } from "i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<section class="auto-grid grid-lg landing">
	<div class="landing-intro stack">
		<h1 class="header">{t("page.home.title")}</h1>
		<p class="subtitle">{t("page.home.tagline")}</p>
		<div class="row">
			<button class="button accent">{t("page.home.get-started-btn")}</button>
			<button class="button">{t("page.home.about-btn")}</button>
		</div>
	</div>
	<LandingWindow></LandingWindow>
</section>

<style>

	.landing {
		min-height: calc(100vh - calc(var(--space-sm) * 2 + var(--header-height)));
		
		.landing-intro {
			justify-content: center;
			min-height: 30vh;
		}

		.header {
			text-align: left;
			font-size: var(--text-4xl);
		}

		.subtitle {
			font-size: var(--text-lg);
		}

	}
</style>

