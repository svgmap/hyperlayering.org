---
import { getCollection, render } from "astro:content";
import BaseLayout from "layouts/BaseLayout.astro";
export async function getStaticPaths() {
	const posts = await getCollection("blog");
	return posts.map((post) => ({
		params: { id: post.id },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = await render(post);
---
<BaseLayout pageTitle={ `Blog - ${post.data.title}` }>
  <article class="blog">
    <section class="stack header-section">
      <small><a href="/blog">blog</a>&nbsp;/&nbsp;{post.id}</small>
      <h1 class="title">{post.data.title}</h1>
      <div>
        <span>{post.data.author}</span>
        &nbsp;&mdash;&nbsp;
        <span>{post.data.pubDate.toLocaleString("en-GB", { dateStyle: "short" })}</span>
      </div>
    </section>
    <hr>
    <section class="content">
      <Content></Content>
    </section>
  </article>
</BaseLayout>

<style scoped>
  .blog {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: var(--space-lg);

    .header-section {
      text-align: center;
      margin: var(--space-md) 0;
    }
    
    .content {
      max-width: var(--paragraph-width);
    }

    .title {
      margin-bottom: auto;
    }

    hr {
      align-self: normal;
    }

    h1 {
      margin-top: auto;
    }
  }
  
</style>